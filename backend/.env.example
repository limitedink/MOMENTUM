NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/momentum
DATABASE_POOL_MAX=10
WEBSOCKET_MAX_MESSAGE_BYTES=16384
WEBSOCKET_MAX_MESSAGES=60
WEBSOCKET_RATE_WINDOW_MS=10000
WEBSOCKET_AUTH_TIMEOUT_MS=5000
WEBSOCKET_IDLE_TIMEOUT_MS=120000
WEBSOCKET_MAX_CONNECTIONS_PER_PLAYER=4
PARTY_STATE_EXPEDITION_DURATION_MS=60000
PARTY_STATE_COMMAND_WINDOW_MS=10000
PARTY_STATE_MAX_COMMANDS=30
PARTY_STATE_CONTRIBUTION_WINDOW_MS=10000
PARTY_STATE_MAX_CONTRIBUTIONS=10
PARTY_STATE_MAX_CONTRIBUTION=1000
PARTY_STATE_MAX_COMMAND_ID_LENGTH=128
PARTY_STATE_MAX_COMMAND_PAYLOAD_BYTES=4096
