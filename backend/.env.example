NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/momentum
DATABASE_POOL_MAX=10
WEBSOCKET_MAX_MESSAGE_BYTES=16384
WEBSOCKET_MAX_MESSAGES=60
WEBSOCKET_RATE_WINDOW_MS=10000
WEBSOCKET_AUTH_TIMEOUT_MS=5000
WEBSOCKET_IDLE_TIMEOUT_MS=120000
WEBSOCKET_MAX_CONNECTIONS_PER_PLAYER=4
